# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real keys.

# Alchemy API key for RPC access
ALCHEMY_KEY=

# Deployment private key
DEPLOY_PRIVATE_KEY=

# Etherscan API key for source verification
ETHERSCAN_KEY=

# Contract addresses (populate after deploy)
COMRADE404_ADDRESS=
COMRADE_HOOK_ADDRESS=
COMRADE_GENESIS_ADDRESS=

# ====== MAINNET LAUNCH PARAMS ======
# Final owner of ComradeHook (controls feeBps + fee withdrawals).
# REQUIRED on mainnet. Multisig recommended (no single-EOA-key risk).
# If unset on chainid=1, DeployComrade reverts.
HOOK_OWNER=

# Recipient of LP fees from the locked launch positions.
# REQUIRED on mainnet (passed to ComradeLPLocker constructor as immutable).
FEE_RECIPIENT=

# v4 PositionManager + WETH for SeedLaunchLPMainnet (mainnet defaults below).
# WETH=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
# POSITION_MANAGER=  # fill in from v4 deploy registry
